# Copia este archivo a .env en el servidor y cambia AMBOS valores.

# Dominio con DNS apuntando al VPS (los QR impresos usarán este dominio).
APP_DOMAIN=app.vectaryx.com

# Clave del panel /plataforma. NO usar la de demo: genera una larga, p. ej.
#   openssl rand -hex 24
VECTARYX_PLATFORM_KEY=cambia-esta-clave-antes-de-desplegar

# =1 sólo en la demo pública: avisa en la pantalla de pago que los números de
# Yape/Plin son ficticios. En un local real déjala sin poner. Ver DEMO.md.
VECTARYX_DEMO=0
